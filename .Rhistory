table %>% filter((grepl("OPC", table$Description)))
table                    <- read_delim("~/Downloads/Chase9947_Activity20250912.CSV")
table                    <- table %>% filter(Type == "Sale")
table                    <- table %>%
mutate(Amount = Amount*(-1))
table$`Transaction Date` <- lubridate::mdy(table$`Transaction Date`)
table                    <- table %>% filter(!(grepl("OPC", table$Description)))
start_date               <- min(table$`Transaction Date`, na.rm = TRUE)
table                    <- table %>% mutate(Week = start_date + floor(as.numeric(`Transaction Date` - start_date) / 7) * 7)
#table <- table %>% filter(!Category == "Mexico")
n      <- length(unique(table$Category))
if (n <= 10) {
colors <- ggsci::pal_npg(palette = "nrc")(n)
} else {
colors <- c(ggsci::pal_npg(palette = "nrc")(10),
ggsci::pal_rickandmorty(palette = "schwifty")(n-10))
}
# Summarize the total Memo amount by Category
category_summary         <- table %>%
group_by(Category) %>%
summarise(Total_Memo = sum(Amount, na.rm = TRUE))
total_spend               <- sum(category_summary$Total_Memo)
category_summary$Category <- gsub(" & ","\n&\n",category_summary$Category)
category_summary$Category <- gsub(" Services","\nServices",category_summary$Category)
P1 <- ggplot(category_summary,
aes(x    = Category,
y    = Total_Memo,
fill = Category)) +
geom_bar(stat = "identity") +
geom_text(aes(label = round(Total_Memo, 1)),
vjust     = -0.5) +  # Labels for total values
scale_fill_manual(values = colors) +
labs(title = "Total Memo Amount by Category",
y     = "Total Memo",
x     = "") +
theme_classic() +
theme(legend.position = "none",  # Hide the legend
axis.text.x     = element_text(angle = 45)) +
annotate("text",
x        = Inf,
y        = Inf,
label    = paste("Total Spend:", round(total_spend, 1)),
hjust    = 1.1,
vjust    = 1.5,
size     = 5,
color    = "black",
fontface = "bold")
category_weekly_summary <- table %>%
group_by(Category, Week) %>%
summarise(Total_Memo = sum(Amount, na.rm = TRUE))
weekly_total            <- category_weekly_summary %>%
group_by(Week) %>%
summarise(Total_Spend = sum(Total_Memo))
category_weekly_summary <- category_weekly_summary %>%
left_join(weekly_total, by = "Week")
# Create the faceted plot by week
P2 <- ggplot(category_weekly_summary,
aes(x = Category,
y = Total_Memo,
fill = Category)) +
geom_bar(stat = "identity") +
facet_wrap(~ Week, nrow = 1) +
geom_text(aes(label = round(Total_Memo, 1)),
vjust = -0.5) +  # Labels for total values
scale_fill_manual(values = colors) +
labs(title = "Total Memo Amount by Category Each Week",
y = "Total Memo",
x = "") +
theme_classic() +
theme(legend.position = "none",  # Hide the legend
axis.text.x = element_text(angle = 45)) +
geom_text(data = weekly_total,
aes(x = Inf,
y = Inf,
label = paste("Total Spend:", round(Total_Spend, 1))),
hjust = 1.1,
vjust = 1.5,
size = 5,
color = "black",
fontface = "bold",
inherit.aes = FALSE)
P1 + P2 + plot_layout(guides = "collect", axes = "collect",design="AA#
BBB")
