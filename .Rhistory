annotate("text",
x        = Inf,
y        = Inf,
label    = paste("Total Spend:", round(total_spend, 1)),
hjust    = 1.1,
vjust    = 1.5,
size     = 5,
color    = "black",
fontface = "bold")
category_weekly_summary <- table %>%
group_by(Category, Week) %>%
summarise(Total_Memo = sum(Amount, na.rm = TRUE))
weekly_total            <- category_weekly_summary %>%
group_by(Week) %>%
summarise(Total_Spend = sum(Total_Memo))
category_weekly_summary <- category_weekly_summary %>%
left_join(weekly_total, by = "Week")
# Create the faceted plot by week
P2 <- ggplot(category_weekly_summary,
aes(x = Category,
y = Total_Memo,
fill = Category)) +
geom_bar(stat = "identity") +
facet_wrap(~ Week, nrow = 1) +
geom_text(aes(label = round(Total_Memo, 1)),
vjust = -0.5) +  # Labels for total values
scale_fill_manual(values = colors) +
